APP_NAME=AarvixCMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/aarvixcms/public

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -------------------------------------------------------
# Database — MySQL 8
# -------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aarvixcms
DB_USERNAME=root
DB_PASSWORD=

# -------------------------------------------------------
# Session / Cache / Queue
# -------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

# local: file | production: redis
CACHE_STORE=file
# CACHE_PREFIX=

# -------------------------------------------------------
# Redis (upgrade queue/cache to this in production)
# -------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -------------------------------------------------------
# Mail — Mailpit for local dev (port 1025 SMTP, 8025 UI)
# -------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="admin@aarvixcms.local"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------
# AWS / S3 (not used in v1 — leave blank)
# -------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
TINYMCE_API_KEY=

# -------------------------------------------------------
# AI (Phase 0 foundation)
# -------------------------------------------------------
AI_ENABLED=false
AI_DEFAULT_PROVIDER=fake
AI_FALLBACK_PROVIDER=fake
AI_QUEUE_HIGH=ai-high
AI_QUEUE_MEDIUM=ai-medium
AI_QUEUE_LOW=ai-low
AI_REQUESTS_PER_MINUTE=30
AI_DAILY_TOKEN_CAP=100000
AI_DAILY_COST_CAP=25.00
AI_MONTHLY_COST_CAP=250.00
AI_LOG_PROMPTS=false
AI_LOG_RESPONSES=false
AI_LOG_RETENTION_DAYS=30
AI_IMAGE_RETENTION_DAYS=30
AI_OPENAI_API_KEY=
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_ORGANIZATION=
AI_OPENAI_TIMEOUT=60
AI_OPENAI_RETRIES=2
AI_OPENAI_CHAT_MODEL=gpt-4.1-mini
AI_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
